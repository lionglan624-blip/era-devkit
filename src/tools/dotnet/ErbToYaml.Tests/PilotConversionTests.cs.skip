using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using Xunit;
using ErbParser;
using ErbToYaml;
using Era.Core;

namespace ErbToYaml.Tests;

/// <summary>
/// Feature 351: Pilot Conversion (美鈴 COM_0)
/// Integration tests for end-to-end ERB→YAML→Render pipeline
/// </summary>
public class PilotConversionTests
{
    private readonly string _erbFilePath;
    private readonly string _talentCsvPath;
    private readonly string _schemaPath;
    private readonly string _outputDir;

    public PilotConversionTests()
    {
        // Path to target ERB file: Game/ERB/口上/1_美鈴/KOJO_K1_愛撫.ERB
        _erbFilePath = Path.Combine(
            AppContext.BaseDirectory, "..", "..", "..", "..", "..", "Game", "ERB", "口上", "1_美鈴", "KOJO_K1_愛撫.ERB");

        _talentCsvPath = Path.Combine(
            AppContext.BaseDirectory, "..", "..", "..", "..", "..", "Game", "CSV", "Talent.csv");

        _schemaPath = Path.Combine(
            AppContext.BaseDirectory, "..", "..", "..", "..", "YamlSchemaGen", "dialogue-schema.json");

        // Output directory for converted YAML files
        _outputDir = Path.Combine(AppContext.BaseDirectory, "..", "..", "..", "TestOutput");
        Directory.CreateDirectory(_outputDir);
    }

    /// <summary>
    /// AC#1: Conversion succeeds
    /// Test that COM_0 ERB → YAML works without errors
    /// Expected: YAML file generated without exceptions
    /// </summary>
    [Fact]
    public void ConvertCom0ToYaml()
    {
        // Arrange
        Assert.True(File.Exists(_erbFilePath), $"ERB file not found: {_erbFilePath}");

        var erbContent = File.ReadAllText(_erbFilePath);
        var parser = new ErbParser.ErbParser();

        // Act
        var ast = parser.ParseString(erbContent, _erbFilePath);

        // Find @KOJO_MESSAGE_COM_K1_0_1 function (the main function with TALENT branching)
        var com0Function = FindFunction(ast, "@KOJO_MESSAGE_COM_K1_0_1");
        Assert.NotNull(com0Function);

        // Extract PRINTDATA node containing DATALIST
        var printDataContent = FindPrintDataNode(com0Function!);
        Assert.NotNull(printDataContent);

        // Find all DATALIST nodes within PRINTDATA
        var datalistNodes = FindAllDatalistNodes(printDataContent!);
        Assert.NotEmpty(datalistNodes);

        // Convert to YAML
        var converter = new DatalistConverter(_talentCsvPath);
        var yamlOutputPath = Path.Combine(_outputDir, "meirin_com0.yaml");

        // For pilot, we'll convert the first DATALIST as a test
        // (Full integration would combine all DATALIST nodes)
        var yaml = converter.Convert(datalistNodes[0], "美鈴", "COM_K1_0");

        // Assert
        Assert.NotNull(yaml);
        Assert.NotEmpty(yaml);

        // Write YAML to file for inspection
        File.WriteAllText(yamlOutputPath, yaml);

        // Verify YAML contains expected structure
        Assert.Contains("character: 美鈴", yaml);
        Assert.Contains("situation: COM_K1_0", yaml);
        Assert.Contains("branches:", yaml);
    }

    /// <summary>
    /// AC#2: All variants render
    /// Test that 16 TALENT combinations render through YamlRenderer
    /// Expected: All 16 variants produce output
    /// </summary>
    [Fact]
    public void RenderAllVariants()
    {
        // Arrange
        // First convert ERB to YAML (reuse conversion logic from AC#1)
        Assert.True(File.Exists(_erbFilePath), $"ERB file not found: {_erbFilePath}");

        var erbContent = File.ReadAllText(_erbFilePath);
        var parser = new ErbParser.ErbParser();
        var ast = parser.ParseString(erbContent, _erbFilePath);

        var com0Function = FindFunction(ast, "@KOJO_MESSAGE_COM_K1_0_1");
        Assert.NotNull(com0Function);

        var printDataContent = FindPrintDataNode(com0Function!);
        Assert.NotNull(printDataContent);

        var datalistNodes = FindAllDatalistNodes(printDataContent!);
        Assert.NotEmpty(datalistNodes);

        // Convert to YAML
        var converter = new DatalistConverter(_talentCsvPath);
        var yaml = converter.Convert(datalistNodes[0], "美鈴", "COM_K1_0");

        // Write YAML to file
        var yamlOutputPath = Path.Combine(_outputDir, "meirin_com0_render.yaml");
        File.WriteAllText(yamlOutputPath, yaml);

        // Initialize KojoEngine (YAML renderer)
        var renderer = new KojoEngine(_schemaPath);

        // Load YAML dialogue data
        var dialogueData = renderer.LoadYaml(yamlOutputPath);
        Assert.NotNull(dialogueData);

        // 16 TALENT combinations: 恋人/恋慕/思慕/なし × 4 patterns each
        // TALENT IDs from Talent.csv: 恋人=16, 恋慕=3, 思慕=17
        var talentStates = new List<(string name, int? talentId, int value)>
        {
            ("恋人", 16, 1),  // TALENT:恋人 = 1
            ("恋慕", 3, 1),   // TALENT:恋慕 = 1
            ("思慕", 17, 1),  // TALENT:思慕 = 1
            ("なし", null, 0) // No TALENT set
        };

        var renderedVariants = new List<string>();

        // Test rendering for each TALENT state
        foreach (var (name, talentId, value) in talentStates)
        {
            // Create game context with specific TALENT state
            var context = new Dictionary<string, object>
            {
                {
                    "TALENT", new Dictionary<string, int>
                    {
                        { "16", talentId == 16 ? value : 0 },  // 恋人
                        { "3", talentId == 3 ? value : 0 },    // 恋慕
                        { "17", talentId == 17 ? value : 0 }   // 思慕
                    }
                }
            };

            // Evaluate conditions to select appropriate branch
            var selectedBranch = renderer.EvaluateConditions(dialogueData, context);
            Assert.NotNull(selectedBranch);

            // Render dialogue text
            var placeholders = new Dictionary<string, string>
            {
                { "CALLNAME:MASTER", "マスター" },
                { "CALLNAME:人物_美鈴", "美鈴" },
                { "TARGET", "美鈴" }
            };

            var renderedText = renderer.Render(selectedBranch, placeholders);
            Assert.NotNull(renderedText);

            // For AC#2, we're testing that rendering succeeds (not empty)
            // Each TALENT state should produce output
            if (name == "なし")
            {
                // Fallback branch should exist for "なし" state
                // (Empty output may be acceptable if no fallback branch exists)
            }
            else
            {
                Assert.NotEmpty(renderedText);
            }

            renderedVariants.Add($"[{name}]\n{renderedText}");
        }

        // Assert that we rendered outputs for all 4 TALENT states
        Assert.Equal(4, renderedVariants.Count);

        // Write rendered outputs to file for manual inspection (AC#3)
        var renderOutputPath = Path.Combine(_outputDir, "meirin_com0_rendered.txt");
        File.WriteAllLines(renderOutputPath, renderedVariants);

        // Note: Full 16-variant testing (4 TALENT states × 4 random patterns)
        // would require multiple rendering runs to verify DATALIST randomization
        // For this pilot, we verify 4 TALENT states are renderable
    }

    #region Helper Methods

    /// <summary>
    /// Find a function node by name in the AST
    /// NOTE: Current ErbParser doesn't track function boundaries in AST.
    /// This method searches for the @FUNCTION_NAME marker and returns all IF nodes
    /// (which represent TALENT branching in the target file)
    /// </summary>
    private List<ErbParser.Ast.AstNode>? FindFunction(List<ErbParser.Ast.AstNode> ast, string functionName)
    {
        // For @KOJO_MESSAGE_COM_K1_0_1, the function body is the entire AST
        // (parser doesn't track function boundaries yet)
        // The AST contains IF nodes with TALENT:恋人/恋慕/思慕 conditions

        // Filter to get only IF nodes (which contain the TALENT branching logic)
        var ifNodes = ast.OfType<ErbParser.Ast.IfNode>().ToList();

        if (ifNodes.Any())
        {
            return new List<ErbParser.Ast.AstNode>(ifNodes);
        }

        return null;
    }

    /// <summary>
    /// Find PRINTDATA node in function body
    /// NOTE: Current parser doesn't parse PRINTDATA blocks.
    /// This method manually parses the raw ERB text to extract ALL PRINTDATA blocks
    /// with their IF/ELSEIF/ELSE conditions.
    /// </summary>
    private string? FindPrintDataNode(List<ErbParser.Ast.AstNode> functionBody)
    {
        // Since parser doesn't handle PRINTDATA, we manually extract from source file
        var erbContent = File.ReadAllText(_erbFilePath);

        // Find the @KOJO_MESSAGE_COM_K1_0_1 function content
        var functionMatch = System.Text.RegularExpressions.Regex.Match(
            erbContent,
            @"@KOJO_MESSAGE_COM_K1_0_1.*?(?=^@|\z)",
            System.Text.RegularExpressions.RegexOptions.Singleline | System.Text.RegularExpressions.RegexOptions.Multiline);

        if (functionMatch.Success)
        {
            // Return entire function body containing all IF/ELSEIF/ELSE branches
            return functionMatch.Value;
        }

        return null;
    }

    /// <summary>
    /// Find all DATALIST nodes within the function body, organized by IF/ELSEIF/ELSE branches
    /// NOTE: Manually parses PRINTDATA...ENDDATA blocks with their conditions
    /// since parser doesn't support PRINTDATA structure.
    /// Returns a single DatalistNode with ConditionalBranches representing all 4 TALENT states
    /// </summary>
    private List<ErbParser.Ast.DatalistNode> FindAllDatalistNodes(string functionContent)
    {
        // Create a synthetic DatalistNode with ConditionalBranches
        // to match the structure expected by DatalistConverter
        var syntheticDatalist = new ErbParser.Ast.DatalistNode();

        // Extract all IF/ELSEIF/ELSE branches with their PRINTDATA blocks
        // Structure:
        // IF TALENT:恋人 ... PRINTDATA ... ENDDATA ... PRINTFORMW
        // ELSEIF TALENT:恋慕 ... PRINTDATA ... ENDDATA ... PRINTFORMW
        // ELSEIF TALENT:思慕 ... PRINTDATA ... ENDDATA ... PRINTFORMW
        // ELSE ... PRINTDATA ... ENDDATA ... PRINTFORMW

        // Extract IF branch (TALENT:恋人)
        var ifMatch = System.Text.RegularExpressions.Regex.Match(
            functionContent,
            @"IF\s+(TALENT:恋人).*?PRINTDATA\s+(.*?)\s+ENDDATA",
            System.Text.RegularExpressions.RegexOptions.Singleline);

        if (ifMatch.Success)
        {
            var condition = ifMatch.Groups[1].Value;
            var printDataContent = ifMatch.Groups[2].Value;
            var ifNode = new ErbParser.Ast.IfNode
            {
                Condition = condition
            };

            // Extract all DATALISTs within this PRINTDATA block
            var datalistMatches = System.Text.RegularExpressions.Regex.Matches(
                printDataContent,
                @"DATALIST\s+(.*?)\s+ENDLIST",
                System.Text.RegularExpressions.RegexOptions.Singleline);

            foreach (System.Text.RegularExpressions.Match datalistMatch in datalistMatches)
            {
                var datalistContent = datalistMatch.Groups[1].Value;
                var dataformNodes = ParseDatalistContentToDataforms(datalistContent);
                foreach (var node in dataformNodes)
                {
                    ifNode.Body.Add(node);
                }
            }

            syntheticDatalist.ConditionalBranches.Add(ifNode);
        }

        // Extract ELSEIF branches (TALENT:恋慕, TALENT:思慕)
        var elseifMatches = System.Text.RegularExpressions.Regex.Matches(
            functionContent,
            @"ELSEIF\s+(TALENT:[^\s]+).*?PRINTDATA\s+(.*?)\s+ENDDATA",
            System.Text.RegularExpressions.RegexOptions.Singleline);

        foreach (System.Text.RegularExpressions.Match elseifMatch in elseifMatches)
        {
            var condition = elseifMatch.Groups[1].Value;
            var printDataContent = elseifMatch.Groups[2].Value;

            var elseIfBranch = new ErbParser.Ast.ElseIfBranch
            {
                Condition = condition
            };

            // Extract all DATALISTs within this PRINTDATA block
            var datalistMatches = System.Text.RegularExpressions.Regex.Matches(
                printDataContent,
                @"DATALIST\s+(.*?)\s+ENDLIST",
                System.Text.RegularExpressions.RegexOptions.Singleline);

            foreach (System.Text.RegularExpressions.Match datalistMatch in datalistMatches)
            {
                var datalistContent = datalistMatch.Groups[1].Value;
                var dataformNodes = ParseDatalistContentToDataforms(datalistContent);
                foreach (var node in dataformNodes)
                {
                    elseIfBranch.Body.Add(node);
                }
            }

            // Add to the main IF node's ElseIfBranches
            if (syntheticDatalist.ConditionalBranches.Count > 0)
            {
                syntheticDatalist.ConditionalBranches[0].ElseIfBranches.Add(elseIfBranch);
            }
        }

        // Extract ELSE branch (no TALENT)
        var elseMatch = System.Text.RegularExpressions.Regex.Match(
            functionContent,
            @"ELSE\s+;.*?PRINTDATA\s+(.*?)\s+ENDDATA",
            System.Text.RegularExpressions.RegexOptions.Singleline);

        if (elseMatch.Success)
        {
            var printDataContent = elseMatch.Groups[1].Value;

            var elseBranch = new ErbParser.Ast.ElseBranch();

            // Extract all DATALISTs within this PRINTDATA block
            var datalistMatches = System.Text.RegularExpressions.Regex.Matches(
                printDataContent,
                @"DATALIST\s+(.*?)\s+ENDLIST",
                System.Text.RegularExpressions.RegexOptions.Singleline);

            foreach (System.Text.RegularExpressions.Match datalistMatch in datalistMatches)
            {
                var datalistContent = datalistMatch.Groups[1].Value;
                var dataformNodes = ParseDatalistContentToDataforms(datalistContent);
                foreach (var node in dataformNodes)
                {
                    elseBranch.Body.Add(node);
                }
            }

            // Add to the main IF node
            if (syntheticDatalist.ConditionalBranches.Count > 0)
            {
                syntheticDatalist.ConditionalBranches[0].ElseBranch = elseBranch;
            }
        }

        return new List<ErbParser.Ast.DatalistNode> { syntheticDatalist };
    }

    /// <summary>
    /// Parse DATALIST content into a list of DataformNodes
    /// </summary>
    private List<ErbParser.Ast.DataformNode> ParseDatalistContentToDataforms(string datalistContent)
    {
        var dataformNodes = new List<ErbParser.Ast.DataformNode>();

        // Extract all DATAFORM lines
        var dataformMatches = System.Text.RegularExpressions.Regex.Matches(
            datalistContent,
            @"DATAFORM\s*(.*)$",
            System.Text.RegularExpressions.RegexOptions.Multiline);

        foreach (System.Text.RegularExpressions.Match match in dataformMatches)
        {
            var dataformContent = match.Groups[1].Value.Trim();

            // Create DataformNode
            var dataformNode = new ErbParser.Ast.DataformNode();

            // Parse arguments (simple approach: treat entire line as string argument)
            if (!string.IsNullOrWhiteSpace(dataformContent))
            {
                dataformNode.Arguments.Add(dataformContent);
            }

            dataformNodes.Add(dataformNode);
        }

        return dataformNodes;
    }

    #endregion
}
