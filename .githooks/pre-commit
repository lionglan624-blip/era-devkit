#!/bin/bash
set -e

# WSL dotnet execution (Smart App Control bypass)
WSL_DOTNET="/home/siihe/.dotnet/dotnet"
# Auto-detect repo path for WSL (convert Windows path to /mnt/ format)
# git rev-parse returns C:/path format in Git Bash
WIN_REPO=$(git rev-parse --show-toplevel)
WSL_REPO=$(echo "$WIN_REPO" | sed -E 's|^([a-zA-Z]):/|/mnt/\L\1/|')
wsl_dotnet() {
    MSYS_NO_PATHCONV=1 wsl -- bash -c "cd $WSL_REPO && $WSL_DOTNET $*"
}

# Log setup - timestamp generated once at top
CI_TIMESTAMP=$(date +"%Y%m%d-%H%M%S")
LOG_DIR="_out/logs/ci"
LOG_FILE="$LOG_DIR/ci-$CI_TIMESTAMP.log"
mkdir -p "$LOG_DIR"

# Collect metadata for log header
BRANCH=$(git branch --show-current 2>/dev/null || echo "detached")
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null)
STAGED_COUNT=$(echo "$STAGED_FILES" | grep -c . 2>/dev/null || true)
FEATURES=$(echo "$STAGED_FILES" | grep -oE 'feature-[0-9]+' 2>/dev/null | sed 's/feature-//' | sort -un | tr '\n' ' ')
FEATURES=${FEATURES:-(none)}

echo "=== Pre-commit CI (devkit) ===" | tee -a "$LOG_FILE"
echo "Date: $(date '+%Y-%m-%d %H:%M:%S')" | tee -a "$LOG_FILE"
echo "Branch: $BRANCH" | tee -a "$LOG_FILE"
echo "Features: $FEATURES" | tee -a "$LOG_FILE"
echo "Staged: $STAGED_COUNT files" | tee -a "$LOG_FILE"
echo "---" | tee -a "$LOG_FILE"
echo "Log: $LOG_FILE"

echo "[0/5] Schema synchronization check..." | tee -a "$LOG_FILE"
.githooks/schema-sync-check

TMP_OUTPUT="$LOG_DIR/.ci-output.tmp"

echo "[1/5] dotnet build devkit.sln..." | tee -a "$LOG_FILE"
set +e
wsl_dotnet build devkit.sln --nologo -v q 2>&1 | tee -a "$LOG_FILE"
BUILD_EXIT_CODE=${PIPESTATUS[0]}
set -e
if [ $BUILD_EXIT_CODE -ne 0 ]; then
  exit $BUILD_EXIT_CODE
fi

# Format check (only if C# files staged)
CS_FILES=$(echo "$STAGED_FILES" | grep -E '\.cs$' || true)
if [ -n "$CS_FILES" ]; then
    echo "[2/5] dotnet format --verify-no-changes..." | tee -a "$LOG_FILE"
    set +e
    wsl_dotnet format devkit.sln --verify-no-changes 2>&1 | tee -a "$LOG_FILE"
    FORMAT_EXIT_CODE=${PIPESTATUS[0]}
    set -e
    if [ $FORMAT_EXIT_CODE -ne 0 ]; then
        echo "ERROR: Code formatting violations found. Run 'dotnet format devkit.sln' to fix." | tee -a "$LOG_FILE"
        exit 1
    fi
else
    echo "[2/5] dotnet format... SKIP (no C# files staged)" | tee -a "$LOG_FILE"
fi

echo "[3/5] dotnet test devkit.sln..." | tee -a "$LOG_FILE"
set +e
wsl_dotnet test devkit.sln --nologo -v m --blame-hang-timeout 10s 2>&1 | tee -a "$LOG_FILE" "$TMP_OUTPUT"
TEST_EXIT_CODE=${PIPESTATUS[0]}
set -e
TEST_OUTPUT=$(cat "$TMP_OUTPUT" 2>/dev/null)
rm -f "$TMP_OUTPUT"

# Log rotation - delete ci-*.log files older than 30 days
find _out/logs/ci -name "ci-*.log" -mtime +30 -delete 2>/dev/null || true

# Check dotnet test exit code first (test failures take precedence)
if [ $TEST_EXIT_CODE -ne 0 ]; then
  exit $TEST_EXIT_CODE
fi

# Validate test count > 0 to prevent false positive (xUnit v3 WDAC issue)
if echo "$TEST_OUTPUT" | grep -qE "(Total|合計):[[:space:]]+0([^0-9]|$)"; then
  echo "ERROR: 0 tests executed. This indicates a test discovery or execution failure."
  exit 1
fi

# Validate test summary exists to prevent crashes/missing output
if echo "$TEST_OUTPUT" | grep -qE '(Total|合計):[[:space:]]+[0-9]+'; then
  : # Test summary found, continue
else
  echo "ERROR: No test summary found in output. This indicates a test runner crash."
  exit 1
fi

echo "[5/5] === CI PASSED ===" | tee -a "$LOG_FILE"
