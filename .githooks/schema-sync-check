#!/bin/bash
# Schema synchronization verification hook
# Ensures src/tools/schemas/com.schema.json and src/tools/go/com-validator/schemas/com.schema.json are identical

set -e

# Get repository root directory
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SCHEMA_SOURCE="$REPO_ROOT/src/tools/schemas/com.schema.json"
SCHEMA_TARGET="$REPO_ROOT/src/tools/go/com-validator/schemas/com.schema.json"

# Check if both files exist
if [ ! -f "$SCHEMA_SOURCE" ]; then
    echo "ERROR: Source schema not found: $SCHEMA_SOURCE"
    exit 1
fi

if [ ! -f "$SCHEMA_TARGET" ]; then
    echo "ERROR: Target schema not found: $SCHEMA_TARGET"
    exit 1
fi

# Compare files
if ! diff -q "$SCHEMA_SOURCE" "$SCHEMA_TARGET" > /dev/null 2>&1; then
    echo "ERROR: Schema files are out of sync!"
    echo "Source: $SCHEMA_SOURCE"
    echo "Target: $SCHEMA_TARGET"
    echo ""
    echo "Please run: cp $SCHEMA_SOURCE $SCHEMA_TARGET"
    exit 1
fi

echo "Schema synchronization verified: OK"
exit 0
